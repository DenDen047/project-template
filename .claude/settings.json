{
    "permissions": {
        "allow": [
            "Bash(gh api:*)",
            "Bash(pixi --version)",
            "Bash(pixi install:*)",
            "Bash(pixi run:*)",
            "Bash(pixi add:*)",
            "Bash(git status:*)",
            "Bash(git diff:*)",
            "Bash(git log:*)",
            "Bash(git branch:*)",
            "Bash(git add:*)",
            "Bash(git commit:*)"
        ]
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/post-edit-python.sh\"",
                        "timeout": 10000,
                        "async": true,
                        "statusMessage": "Formatting & linting..."
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/pre-commit-lint.sh\"",
                        "timeout": 30000,
                        "async": false,
                        "statusMessage": "Pre-commit lint check..."
                    }
                ]
            }
        ]
    }
}
